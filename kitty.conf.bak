# =========================
# FUENTE
# =========================

# Fuente principal del terminal
font_family         Inconsolata Nerd Font 

# Fuente para texto en negrita
# "auto" usa automáticamente la variante bold de la fuente principal
# bold_font        auto

# Fuente para texto en cursiva
# italic_font      auto

# Fuente para texto bold + italic
# bold_italic_font auto

# Tamaño de fuente
font_size 15.0


# =========================
# CURSOR
# =========================

# Color del texto cuando el cursor lo cubre
# (más útil en cursor tipo block)
cursor_text_color #87d3c4

# Forma del cursor:
# block | beam | underline
# beam = línea vertical tipo editor moderno
cursor_shape beam

# Cantidad de "trail" o estela visual del cursor
cursor_trail 3

# Velocidad de desaparición del trail
# primer valor = fade inicial
# segundo valor = fade final
cursor_trail_decay 0.1 0.4

# Distancia mínima de movimiento para activar el trail
cursor_trail_start_threshold 2

# Color de la estela del cursor
cursor_trail_color #87d3c4

# Grosor del cursor tipo beam
cursor_beam_thickness 1.5

# Tiempo en segundos antes de detener el parpadeo del cursor
cursor_stop_blinking_after 15.0


# =========================
# SCROLL
# =========================

# Cantidad de líneas almacenadas en historial scrollback
scrollback_lines 1000


# =========================
# MOUSE
# =========================

# Copia automáticamente texto al seleccionarlo con el mouse
copy_on_select yes


# =========================
# SONIDO Y ALERTAS
# =========================

# Desactiva el sonido del terminal
enable_audio_bell no

# Duración del flash visual al emitir una alerta
visual_bell_duration 0.1


# =========================
# VENTANA
# =========================

# Grosor del borde de la ventana
window_border_width 0.1

# Dibuja bordes minimalistas entre ventanas split
draw_minimal_borders yes

# Padding interno de la ventana
# agrega espacio entre texto y borde
window_padding_width 30

# Color del borde de la ventana activa
active_border_color #1D1D1D

# Color del borde de ventanas inactivas
inactive_border_color #5AEDA3


# =========================
# TABS
# =========================

# Estilo visual de la barra de tabs
# fade = tabs con transición suave
tab_bar_style fade

# Alineación de tabs
# left | center | right
tab_bar_align center

# Color del texto del tab activo
active_tab_foreground   #1D1D1D

# Fondo del tab activo
active_tab_background   #19A0B4

# Estilo de fuente del tab activo
# (esta línea probablemente no tiene efecto válido)
active_tab_font_style   inconsolata 

# Texto de tabs inactivos
inactive_tab_foreground #5AEDA3

# Fondo de tabs inactivos
inactive_tab_background #1d1d1d

# Estilo fuente tabs inactivos
inactive_tab_font_style inconsolata 


# # =========================
# # COLORES GENERALES
# # =========================

# # Color principal del texto
# foreground #DEDDDA

# # Color de fondo del terminal
# background #060F0A

# # Transparencia del fondo
# # 1.0 = sólido
# # 0.0 = completamente transparente
# background_opacity 0.9


# # =========================
# # SELECCIÓN DE TEXTO
# # =========================

# # Color del texto seleccionado
# selection_foreground #35b1d2

# # Fondo del texto seleccionado
# selection_background #222222


# # =========================
# # PALETA ANSI
# # =========================

# # Colores ANSI básicos usados por programas CLI


# # ----- BLACK -----
# color0 #222222
# color8 #348558


# # ----- RED -----
# color1 #e2a8bf	
# color9 #ffcdd9


# # ----- GREEN -----
# color2  #81d778
# color10 #beffa8


# # ----- YELLOW -----
# color3  #c4c9c0
# color11 #d0ccca


# # ----- BLUE -----
# color4  #325856
# color12 #7ab0d2


# # ----- MAGENTA -----
# color5  #a481d3
# color13 #c5a7d9


# # ----- CYAN -----
# color6  #15ab9c
# color14 #8cdfe0


# # ----- WHITE -----
# color7  #02c5e0
# color15 #e0e0e0


# =========================
# CONTROL REMOTO
# =========================

# Permite controlar kitty desde scripts externos
# útil para automatización avanzada
allow_remote_control yes


# =========================
# ATAJOS DE TECLADO
# =========================

# Cambia foco entre ventanas visibles con:
# kitty_mod normalmente = ctrl+shift
map kitty_mod+f7 focus_visible_window

# Cambia foco entre ventanas usando Ctrl+Tab
map ctrl+tab focus_visible_window

foreground #e1e1e1
background #1e1e1e

color0  #2a2a2a
color8  #5a5a5a

color1  #ff7a90
color9  #ffb3c1

color2  #7ce38b
color10 #b8ffb5

color3  #d6d68a
color11 #f0e68c

color4  #5fb3ff
color12 #9ad1ff

color5  #c792ea
color13 #ddb3ff

color6  #4fd6be
color14 #98f5e1

color7  #cfcfcf
color15 #ffffff
